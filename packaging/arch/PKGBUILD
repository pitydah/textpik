# Maintainer: selectxt contributors
# Contributor: Your Name <your@email.com>

pkgname=selectxt
pkgver=0.11.0
pkgrel=1
pkgdesc="Popup action bar on text selection for Linux (KDE Plasma integration)"
arch=('any')
url="https://github.com/<user>/selectxt"
license=('GPL3')
depends=('python' 'pyside6' 'wl-clipboard' 'xdotool' 'qt6-svg')
optdepends=('ydotool: auto-paste on Wayland'
            'wtype: auto-paste on Wayland'
            'konsole: terminal action'
            'ollama: AI query action')
source=("$pkgname-$pkgver.tar.gz::https://github.com/<user>/selectxt/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
    cd "$srcdir/$pkgname-$pkgver"
    install -Dm755 src/selectxt.py "$pkgdir/usr/bin/selectxt"
    install -Dm644 assets/app/selectxt.svg "$pkgdir/usr/share/icons/hicolor/scalable/apps/selectxt.svg"
    install -Dm644 packaging/selectxt.desktop "$pkgdir/usr/share/applications/selectxt.desktop"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    cp -r assets "$pkgdir/usr/share/selectxt/"
    cp -r kwin "$pkgdir/usr/share/selectxt/"
}
